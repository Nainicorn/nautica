<div class="__viewer-container">
    <div class="__viewer-overlay-top">
        <div class="__viewer-tag">
            <span class="__viewer-tag-dot"></span>
            <span class="__viewer-tag-text">LIVE FEED</span>
        </div>
    </div>

    <div class="__viewer-canvas-container">
        <img class="__viewer-frame" alt="" />
        <canvas class="__viewer-canvas"></canvas>
        <div class="__viewer-loading">
            <span class="material-icon __viewer-loading-icon">sync</span>
            <span class="__viewer-loading-text">LOADING FRAMES...</span>
        </div>
    </div>

    <div class="__viewer-empty">
        <span class="material-icon __viewer-empty-icon">sailing</span>
        <span class="__viewer-empty-title">NO ACTIVE FEED</span>
        <span class="__viewer-empty-subtitle">Upload footage or select a session to begin analysis</span>
    </div>

    <div class="__viewer-controls">
        <div class="__viewer-controls-left">
            <button class="__viewer-control-btn __viewer-btn-step-back" title="Step Back">
                <span class="material-icon">skip_previous</span>
            </button>
            <button class="__viewer-control-btn __viewer-btn-play" title="Play">
                <span class="material-icon">play_arrow</span>
            </button>
            <button class="__viewer-control-btn __viewer-btn-step-forward" title="Step Forward">
                <span class="material-icon">skip_next</span>
            </button>
            <span class="__viewer-timecode">Frame 0 / 0</span>
        </div>
        <div class="__viewer-progress">
            <div class="__viewer-progress-bar"></div>
            <div class="__viewer-progress-handle"></div>
        </div>
        <div class="__viewer-controls-right">
            <span class="__viewer-speed-label">5 FPS</span>
            <button class="__viewer-control-btn __viewer-btn-overlay __viewer-control-btn--active" title="Detection Overlay">
                <span class="material-icon">layers</span>
            </button>
            <button class="__viewer-control-btn __viewer-btn-fullscreen" title="Fullscreen">
                <span class="material-icon">fullscreen</span>
            </button>
        </div>
    </div>
</div>
