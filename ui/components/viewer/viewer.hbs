<div class="__viewer-container">
    <div class="__viewer-overlay-top">
        <div class="__viewer-tag">
            <span class="__viewer-tag-dot"></span>
            <span class="__viewer-tag-text">LIVE FEED</span>
        </div>
        <div class="__viewer-tag __viewer-tag--dim">
            <span class="material-icon" style="font-size: 14px;">videocam</span>
            <span class="__viewer-tag-text">CAM-01 AERIAL</span>
        </div>
    </div>
    <div class="__viewer-empty">
        <span class="material-icon __viewer-empty-icon">sailing</span>
        <span class="__viewer-empty-title">NO ACTIVE FEED</span>
        <span class="__viewer-empty-subtitle">Upload footage or select a session to begin analysis</span>
    </div>
    <div class="__viewer-controls">
        <div class="__viewer-controls-left">
            <button class="__viewer-control-btn" title="Play">
                <span class="material-icon">play_arrow</span>
            </button>
            <button class="__viewer-control-btn" title="Stop">
                <span class="material-icon">stop</span>
            </button>
            <span class="__viewer-timecode">00:00:00 / 00:00:00</span>
        </div>
        <div class="__viewer-progress">
            <div class="__viewer-progress-bar"></div>
        </div>
        <div class="__viewer-controls-right">
            <button class="__viewer-control-btn" title="Detection Overlay">
                <span class="material-icon">layers</span>
            </button>
            <button class="__viewer-control-btn" title="Fullscreen">
                <span class="material-icon">fullscreen</span>
            </button>
        </div>
    </div>
</div>
