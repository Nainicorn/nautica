<div class="__metrics-container">
    <div class="__metrics-header">
        <span class="material-icon">monitoring</span>
        <span class="__metrics-title">METRICS</span>
    </div>
    <div class="__metrics-grid">
        <div class="__metrics-card">
            <span class="__metrics-card-label">Vessels Detected</span>
            <span class="__metrics-card-value __metrics-card-value--accent">{{vessels}}</span>
        </div>
        <div class="__metrics-card">
            <span class="__metrics-card-label">Active Tracks</span>
            <span class="__metrics-card-value __metrics-card-value--blue">{{tracks}}</span>
        </div>
        <div class="__metrics-card">
            <span class="__metrics-card-label">Anomalies</span>
            <span class="__metrics-card-value __metrics-card-value--alert">{{anomalyCount}}</span>
        </div>
        <div class="__metrics-card">
            <span class="__metrics-card-label">Avg Confidence</span>
            <span class="__metrics-card-value __metrics-card-value--muted __metrics-card-value--conf">{{avgConfidence}}</span>
        </div>
    </div>
</div>
